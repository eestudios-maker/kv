      var td=document.createElement('td');
      td.style.cssText='padding:4px 6px;border:1px solid var(--border);background:var(--surface);vertical-align:top;';
      var matching=artistCards.filter(function(c){
        var day=dayOverrides[c.id]||c.day;
        if(!day||day==='TBD')return false;
