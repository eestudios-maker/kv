// ========================= DATE PICKER =========================
function openDatePicker(inputEl,fmt){
  dpInputEl=inputEl;dpFmt=fmt;
  var now=dpParseCurrent(inputEl.value,fmt);
  dpYear=now.year;dpMonth=now.month;
  var picker=document.getElementById('date-picker');
  if(!picker)return;
  var rect=inputEl.getBoundingClientRect();
  picker.style.top=(rect.bottom+window.scrollY+4)+'px';
  picker.style.left=Math.min(rect.left,window.innerWidth-230)+'px';
  picker.style.display='block';
  dpRender();
}
function closeDatePicker(){
  var picker=document.getElementById('date-picker');
  if(picker)picker.style.display='none';
  dpInputEl=null;
}
function dpParseCurrent(val,fmt){
  var months={Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  var now=new Date();
  if(val&&val!=='TBD'){
    var m=val.match(/([A-Z][a-z]{2})\s+(\d+)/);
    if(m&&months[m[1]]!==undefined)return {year:now.getFullYear(),month:months[m[1]],day:parseInt(m[2])};
  }
  return {year:now.getFullYear(),month:now.getMonth(),day:null};
}
function dpRender(){
  var lbl=document.getElementById('dp-month-label');
  var daysEl=document.getElementById('dp-days');
  if(!lbl||!daysEl)return;
  var monthNames=['January','February','March','April','May','June','July','August','September','October','November','December'];
  lbl.textContent=monthNames[dpMonth]+' '+dpYear;
  daysEl.innerHTML='';
  var firstDay=new Date(dpYear,dpMonth,1).getDay();
  var daysInMonth=new Date(dpYear,dpMonth+1,0).getDate();
  var cur=dpInputEl?dpParseCurrent(dpInputEl.value,dpFmt):{year:0,month:-1,day:null};
  for(var i=0;i<firstDay;i++){
    var emp=document.createElement('div');emp.className='dp-day empty';daysEl.appendChild(emp);
  }
  for(var d=1;d<=daysInMonth;d++){
    var btn=document.createElement('button');
    btn.className='dp-day'+(cur.year===dpYear&&cur.month===dpMonth&&cur.day===d?' selected':'');
    btn.textContent=d;
    (function(day){
      btn.addEventListener('click',function(){
        if(!dpInputEl)return;
        dpInputEl.value=dpFormat(dpYear,dpMonth,day,dpFmt);
        dpInputEl.dispatchEvent(new Event('change'));
        closeDatePicker();
      });
    })(d);
    daysEl.appendChild(btn);
  }
}
function dpFormat(year,month,day,fmt){
  var dows=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  var dt=new Date(year,month,day);
  if(fmt==='upload')return dows[dt.getDay()]+' '+months[month]+' '+day;
  return months[month]+' '+day;
}

// ========================= ACTIVITY LOG =========================
function logActivity(msg){
  activityLog.unshift({msg:msg,time:new Date().toLocaleTimeString()});
  if(activityLog.length>50)activityLog=activityLog.slice(0,50);
  renderActivityLog();
}
function renderActivityLog(){
  var el=document.getElementById('activity-list');
  if(!el)return;
  if(!activityLog.length){el.innerHTML='<div class="activity-empty">No activity yet</div>';return;}
  el.innerHTML=activityLog.map(function(a){
    return '<div class="activity-item"><div class="activity-msg">'+escHtml(a.msg)+'</div><div class="activity-time">'+a.time+'</div></div>';
  }).join('');
}

// ========================= MODAL =========================
function openCard(id){
  var c=findCard(id);
  if(!c)return;
  activeCard=id;
  var wid=cardWeekAssign[id]||getOrigWeekId(c);
  var wk=getAllWeeks().filter(function(w){return w.id===wid;})[0];
  var up=uploadedStatus[id];
  var st=getCardStatus(c);

  var tag=document.getElementById('m-tag');
  var art=document.getElementById('m-artist');
  var di=document.getElementById('m-detail-input');
  var yi=document.getElementById('m-yt-input');
  var yl=document.getElementById('m-yt-link');
  var ni=document.getElementById('m-notes-input');
  var dyi=document.getElementById('m-day-input');
  var shi=document.getElementById('m-shoot-input');
  var wkEl=document.getElementById('m-week');
  var stEl=document.getElementById('m-status');
  var tb=document.getElementById('m-toggle-btn');
  var dc=document.getElementById('delete-confirm');

  if(tag){tag.textContent=tagLabel(c.type);tag.className='card-tag modal-tag '+c.type;}
  if(art)art.textContent=c.artist;
  if(di)di.value=detailLabels[id]||c.detail;
  if(yi)yi.value=youtubeLinks[id]||'';
  if(yl){
    var ytUrl=youtubeLinks[id];
    yl.href=ytUrl||'#';
    yl.style.display=ytUrl?'block':'none';
    yl.textContent=ytUrl?'Watch on YouTube':'';
  }
  if(ni)ni.value=cardNotes[id]||'';
  if(dyi){
    dyi.value=dayOverrides[id]||c.day||'TBD';
    dyi.onclick=function(){openDatePicker(dyi,'upload');};
  }
  if(shi){
    shi.value=shootOverrides[id]||c.shoot||'TBD';
    shi.onclick=function(){openDatePicker(shi,'shoot');};
  }
  if(wkEl)wkEl.textContent=wk?wk.label:'';
  var ed=editedStatus[id];
  if(stEl){
    if(up)stEl.innerHTML='<span style="color:var(--int)">\u2713 Uploaded</span>';
    else if(ed)stEl.innerHTML='<span style="color:#a855f7">\u2713 Done Editing</span>';
    else if(st==='overdue')stEl.innerHTML='<span style="color:var(--overdue)">\u26a0 Overdue</span>';
    else if(st==='soon')stEl.innerHTML='<span style="color:var(--soon)">\u23f0 This week</span>';
    else stEl.textContent='Scheduled';
  }
  if(tb){
    if(up){tb.textContent='Revert to done editing';tb.className='btn btn-secondary';}
    else if(ed){tb.textContent='Mark as uploaded';tb.className='btn btn-primary';}
    else{tb.textContent='Mark as done editing';tb.className='btn btn-primary';tb.style.background='#a855f7';tb.style.borderColor='#a855f7';}
  }
  if(dc)dc.style.display='none';

  document.getElementById('modal-overlay').classList.add('open');
}
function closeModal(){
  document.getElementById('modal-overlay').classList.remove('open');
  closeDatePicker();
  activeCard=null;
}
function openAddCard(wid){
  var sel=document.getElementById('ac-week');
  if(sel){
    sel.innerHTML='';
    getAllWeeks().forEach(function(w){
      var opt=document.createElement('option');
      opt.value=w.id;opt.textContent=w.label;
      if(w.id===wid)opt.selected=true;
      sel.appendChild(opt);
    });
  }
  document.getElementById('ac-artist').value='';
  document.getElementById('ac-detail').value='';
  document.getElementById('ac-day').value='TBD';
  document.getElementById('ac-shoot').value='TBD';
  document.getElementById('add-card-overlay').classList.add('open');
}

// ========================= EVENT LISTENERS =========================
document.addEventListener('DOMContentLoaded',function(){
  // Init data labels
  WEEKS.forEach(function(w){w.cards.forEach(function(c){detailLabels[c.id]=c.detail;});});
  WEEKS_S2.forEach(function(w){w.cards.forEach(function(c){detailLabels[c.id]=c.detail;});});

  // Pre-seed Season 1 uploaded
  // No pre-seeded uploads — all content starts as Scheduled

  // Load state from localStorage
  var saved=null;
  try{var raw=localStorage.getItem(LSK);if(raw)saved=JSON.parse(raw);}catch(e){}
  var dels=null;
  try{var rd=localStorage.getItem(LSDK);if(rd)dels=JSON.parse(rd);}catch(e){}
  initBoard(saved);
  if(dels&&dels.length)dels.forEach(function(id){deletedCards[id]=true;});

  _hist=[_snap()];_hi=0;_upUR();
  updateSeasonUI();

  // Hide loading screen
  setTimeout(function(){
    var ls=document.getElementById('loading-screen');
    if(ls)ls.classList.add('hidden');
    switchView('board');
    calMonth=(new Date()).getMonth();
    calYear=(new Date()).getFullYear();
  },600);

  // ---- UNDO / REDO ----
  document.getElementById('undo-btn').addEventListener('click',function(){
    if(_hi>0){_hi--;_apply(_hist[_hi]);_upUR();renderBoard();renderActivityLog();updateStats();}
  });
  document.getElementById('redo-btn').addEventListener('click',function(){
    if(_hi<_hist.length-1){_hi++;_apply(_hist[_hi]);_upUR();renderBoard();renderActivityLog();updateStats();}
  });
  document.addEventListener('keydown',function(e){
    if((e.ctrlKey||e.metaKey)&&e.key==='z'&&!e.shiftKey){
      e.preventDefault();
      if(_hi>0){_hi--;_apply(_hist[_hi]);_upUR();renderBoard();renderActivityLog();updateStats();}
    }
    if((e.ctrlKey||e.metaKey)&&(e.key==='y'||(e.key==='z'&&e.shiftKey))){
      e.preventDefault();
      if(_hi<_hist.length-1){_hi++;_apply(_hist[_hi]);_upUR();renderBoard();renderActivityLog();updateStats();}
    }
  });

  // ---- VIEW BUTTONS ----
  document.getElementById('view-board-btn').addEventListener('click',function(){switchView('board');});
  document.getElementById('view-artist-btn').addEventListener('click',function(){switchView('artist');});
  document.getElementById('view-timeline-btn').addEventListener('click',function(){switchView('timeline');});
  document.getElementById('view-cal-btn').addEventListener('click',function(){switchView('cal');});

  // ---- SEASON SWITCH ----
  document.getElementById('season-s1-btn').addEventListener('click',function(){switchSeason(1);});
  document.getElementById('season-s2-btn').addEventListener('click',function(){switchSeason(2);});

  // ---- FILTER ----
  document.querySelectorAll('.filter-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      activeFilter=btn.dataset.filter;
      document.querySelectorAll('.filter-btn').forEach(function(b){
        b.classList.toggle('active',b.dataset.filter===activeFilter);
      });
      if(currentView==='board')renderBoard();
    });
  });

  // ---- SEARCH ----
  document.getElementById('search-input').addEventListener('input',function(){
    searchQuery=this.value.trim();
    if(currentView==='board')renderBoard();
  });

  // ---- SORT BUTTONS (delegated) ----
  document.getElementById('board').addEventListener('click',function(e){
    var sb=e.target.closest('.sort-btn');
    if(!sb)return;
    var wid=sb.dataset.week;var sort=sb.dataset.sort;
    if(sort==='add'){openAddCard(wid);return;}
    if(sortOrders[wid]===sort)sortOrders[wid]='default';
    else sortOrders[wid]=sort;
    pushHistory();renderBoard();persistState();
  });

  // ---- MODAL ACTIONS ----
  document.getElementById('modal-close').addEventListener('click',closeModal);
  document.getElementById('modal-close2').addEventListener('click',closeModal);
  document.getElementById('modal-overlay').addEventListener('click',function(e){
    if(e.target===this)closeModal();
  });

  document.getElementById('m-toggle-btn').addEventListener('click',function(){
    if(!activeCard)return;
    var c=findCard(activeCard);
    var name=c?(c.artist+' \u2013 '+(detailLabels[activeCard]||c.detail)):'';
    var up=uploadedStatus[activeCard];
    var ed=editedStatus[activeCard];
    if(up){
      // Uploaded → revert to Done Editing
      uploadedStatus[activeCard]=false;
      editedStatus[activeCard]=true;
      logActivity('\u21ba Reverted to editing: '+name);
    } else if(ed){
      // Done Editing → Uploaded
      uploadedStatus[activeCard]=true;
      logActivity('\u2713 Uploaded: '+name);
    } else {
      // Scheduled → Done Editing
      editedStatus[activeCard]=true;
      logActivity('\u2713 Done editing: '+name);
    }
    pushHistory();closeModal();renderBoard();updateStats();persistState();
  });

  document.getElementById('m-save-btn').addEventListener('click',function(){
    if(!activeCard)return;
    var di=document.getElementById('m-detail-input');
    if(di)detailLabels[activeCard]=di.value;
    var yi=document.getElementById('m-yt-input');
    if(yi)youtubeLinks[activeCard]=yi.value;
    var ni=document.getElementById('m-notes-input');
    if(ni)cardNotes[activeCard]=ni.value;
    var dyi=document.getElementById('m-day-input');
    if(dyi){
      dayOverrides[activeCard]=dyi.value;
      var c=findCard(activeCard);if(c)c.day=dyi.value;
    }
    var shi=document.getElementById('m-shoot-input');
    if(shi){
      shootOverrides[activeCard]=shi.value;
      var c=findCard(activeCard);if(c)c.shoot=shi.value;
    }
    pushHistory();renderBoard();updateStats();persistState();
    openCard(activeCard); // refresh modal
  });

  document.getElementById('m-day-input').addEventListener('change',function(){
    if(!activeCard)return;
    dayOverrides[activeCard]=this.value;
    var c=findCard(activeCard);if(c)c.day=this.value;
  });
  document.getElementById('m-shoot-input').addEventListener('change',function(){
    if(!activeCard)return;
    shootOverrides[activeCard]=this.value;
    var c=findCard(activeCard);if(c)c.shoot=this.value;
  });

  // Delete card
  document.getElementById('m-delete-btn').addEventListener('click',function(){
    if(!activeCard)return;
    deletedCards[activeCard]=true;
    var c=findCard(activeCard);
    if(c)logActivity('\u{1F5D1} Deleted: '+c.artist);
    pushHistory();closeModal();renderBoard();updateStats();persistState();
  });
  document.getElementById('m-delete-cancel').addEventListener('click',function(){
    document.getElementById('delete-confirm').style.display='none';
  });
  // Show delete confirm on right-click card (handled via context of modal - add delete btn)
  // Add a delete trigger in modal actions
  var modalActions=document.getElementById('modal-actions');
  if(modalActions){
    var delTrigger=document.createElement('button');
    delTrigger.className='btn btn-danger';
    delTrigger.textContent='Delete card';
    delTrigger.addEventListener('click',function(){
      document.getElementById('delete-confirm').style.display='block';
    });
    modalActions.appendChild(delTrigger);
  }

  // ---- ADD CARD MODAL ----
  document.getElementById('add-card-close').addEventListener('click',function(){
    document.getElementById('add-card-overlay').classList.remove('open');
  });
  document.getElementById('add-card-cancel').addEventListener('click',function(){
    document.getElementById('add-card-overlay').classList.remove('open');
  });
  document.getElementById('add-card-overlay').addEventListener('click',function(e){
    if(e.target===this)this.classList.remove('open');
  });
  document.getElementById('ac-submit').addEventListener('click',function(){
    var artist=document.getElementById('ac-artist').value.trim();
    var detail=document.getElementById('ac-detail').value.trim();
    if(!artist||!detail){alert('Artist and description are required.');return;}
    var type=document.getElementById('ac-type').value;
    var day=document.getElementById('ac-day').value||'TBD';
    var shoot=document.getElementById('ac-shoot').value||'TBD';
    var wid=document.getElementById('ac-week').value;
    var id='cc_'+Date.now();
    var card={id:id,artist:artist,detail:detail,type:type,day:day,shoot:shoot};
    customCards.push(card);
    detailLabels[id]=detail;
    cardWeekAssign[id]=wid;
    logActivity('+ Added: '+artist+' \u2013 '+detail);
    pushHistory();
    document.getElementById('add-card-overlay').classList.remove('open');
    renderBoard();updateStats();persistState();
  });

  // ---- ADD COLUMN MODAL ----
  document.getElementById('add-col-close').addEventListener('click',function(){
    document.getElementById('add-col-overlay').classList.remove('open');
  });
  document.getElementById('add-col-cancel').addEventListener('click',function(){
    document.getElementById('add-col-overlay').classList.remove('open');
  });
  document.getElementById('add-col-overlay').addEventListener('click',function(e){
    if(e.target===this)this.classList.remove('open');
  });
  document.getElementById('acol-submit').addEventListener('click',function(){
    var name=document.getElementById('acolname').value.trim();
    if(!name){alert('Column name required.');return;}
    var date=document.getElementById('acoldate').value.trim();
    var id='cw_'+Date.now();
    customWeeks.push({id:id,label:name,date:date,cards:[]});
    logActivity('+ New column: '+name);
    pushHistory();
    document.getElementById('add-col-overlay').classList.remove('open');
    renderBoard();persistState();
  });

  // ---- ACTIVITY PANEL ----
  document.getElementById('activity-toggle-btn').addEventListener('click',function(){
    var panel=document.getElementById('activity-panel');
    panel.classList.toggle('open');
    renderActivityLog();
  });
  document.getElementById('activity-close').addEventListener('click',function(){
    document.getElementById('activity-panel').classList.remove('open');
  });

  // ---- CALENDAR NAV ----
  document.getElementById('cal-prev-btn').addEventListener('click',function(){
    calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCalendar();
  });
  document.getElementById('cal-next-btn').addEventListener('click',function(){
    calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCalendar();
  });
  document.getElementById('cal-today-btn').addEventListener('click',function(){
    var now=new Date();calMonth=now.getMonth();calYear=now.getFullYear();renderCalendar();
  });

  // ---- DATE PICKER ----
  document.getElementById('dp-prev').addEventListener('click',function(){
    dpMonth--;if(dpMonth<0){dpMonth=11;dpYear--;}dpRender();
  });
  document.getElementById('dp-next').addEventListener('click',function(){
    dpMonth++;if(dpMonth>11){dpMonth=0;dpYear++;}dpRender();
  });
  document.getElementById('dp-clear').addEventListener('click',function(){
    if(dpInputEl){dpInputEl.value='TBD';dpInputEl.dispatchEvent(new Event('change'));}
    closeDatePicker();
  });
  document.addEventListener('click',function(e){
    var picker=document.getElementById('date-picker');
    if(!picker||picker.style.display==='none')return;
    if(!picker.contains(e.target)&&e.target!==dpInputEl)closeDatePicker();
  });

  // ---- MILESTONE DISMISS ----
  document.getElementById('ms-dismiss').addEventListener('click',function(){
    document.getElementById('milestone-banner').classList.remove('show');
  });
});
</script>
</body>
</html>
