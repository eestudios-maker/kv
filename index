  {id:'s2_wup',label:'Upcoming',date:'',cards:[]}
];

// ========================= STATE =========================
var IS_AS=false; // Google Apps Script integration (future)
var uploadedStatus={},editedStatus={},detailLabels={},deletedCards={},dayOverrides={},shootOverrides={};
var youtubeLinks={},cardNotes={},cardWeekAssign={};
var customWeeks=[],customCards=[],sortOrders={},activityLog=[],cardOrder={};
var activeFilter='all',searchQuery='',activeCard=null,saveTimer=null;
var currentSeason=1;
var LSK='kv_music_state',LSDK='kv_music_deleted';
var LSK_S2='kv_music_state_s2',LSDK_S2='kv_music_deleted_s2';
var _hist=[],_hi=-1;
var _milestoneShown={};
var dpInputEl=null,dpFmt='upload',dpYear=2026,dpMonth=2;
var currentView='board';
var calYear=2026,calMonth=2;
var dragSrcId=null;

// ========================= UNDO/REDO =========================
function _snap(){
  return {
    up:JSON.stringify(uploadedStatus),
    ed:JSON.stringify(editedStatus),
    dl:JSON.stringify(detailLabels),
    dc:JSON.stringify(deletedCards),
    dy:JSON.stringify(dayOverrides),
    sh:JSON.stringify(shootOverrides),
    yl:JSON.stringify(youtubeLinks),
    cn:JSON.stringify(cardNotes),
    cw:JSON.stringify(cardWeekAssign),
    cwo:JSON.stringify(customWeeks),
    cc:JSON.stringify(customCards),
    so:JSON.stringify(sortOrders),
    al:JSON.stringify(activityLog),
    co:JSON.stringify(cardOrder)
  };
}
function _apply(s){
  uploadedStatus=JSON.parse(s.up);
  editedStatus=JSON.parse(s.ed||'{}');
  detailLabels=JSON.parse(s.dl);
  deletedCards=JSON.parse(s.dc);
  dayOverrides=JSON.parse(s.dy);
  shootOverrides=JSON.parse(s.sh||'{}');
  youtubeLinks=JSON.parse(s.yl||'{}');
  cardNotes=JSON.parse(s.cn||'{}');
  cardWeekAssign=JSON.parse(s.cw);
  customWeeks=JSON.parse(s.cwo||'[]');
  customCards=JSON.parse(s.cc||'[]');
  sortOrders=JSON.parse(s.so||'{}');
  activityLog=JSON.parse(s.al||'[]');
  cardOrder=JSON.parse(s.co||'{}');
  // restore card day/shoot from overrides
  getAllCards().forEach(function(c){
    if(dayOverrides[c.id])c.day=dayOverrides[c.id];
    if(shootOverrides[c.id])c.shoot=shootOverrides[c.id];
  });
}
function pushHistory(){
  if(_hi<_hist.length-1)_hist=_hist.slice(0,_hi+1);
  _hist.push(_snap());
  if(_hist.length>80)_hist.shift();
  _hi=_hist.length-1;
  _upUR();
}
function _upUR(){
  var u=document.getElementById('undo-btn'),r=document.getElementById('redo-btn');
  if(u)u.disabled=(_hi<=0);
  if(r)r.disabled=(_hi>=_hist.length-1);
}

// ========================= HELPERS =========================
function getActiveBaseWeeks(){return currentSeason===1?WEEKS:WEEKS_S2;}
function getAllWeeks(){return getActiveBaseWeeks().concat(customWeeks);}
function getAllCards(){
  var cs=[];
  getActiveBaseWeeks().forEach(function(w){w.cards.forEach(function(c){cs.push(c);});});
  customCards.forEach(function(c){cs.push(c);});
  return cs;
}
function findCard(id){
  var found=null;
  getAllCards().forEach(function(c){if(c.id===id)found=c;});
  return found;
}
function getOrigWeekId(c){
  if(!c)return '';
  var found='';
  getActiveBaseWeeks().forEach(function(w){
    w.cards.forEach(function(wc){if(wc.id===c.id)found=w.id;});
  });
  if(!found){
    customWeeks.forEach(function(w){
      w.cards.forEach(function(wc){if(wc.id===c.id)found=w.id;});
    });
  }
  return found||'';
}
function getCardsForWeek(wid){
  var cards=[];
  var weeks=getAllWeeks();
  var wk=weeks.filter(function(w){return w.id===wid;})[0];
  if(wk)wk.cards.forEach(function(c){cards.push(c);});
  // cards moved here
  getAllCards().forEach(function(c){
    if(cardWeekAssign[c.id]===wid&&getOrigWeekId(c)!==wid)cards.push(c);
  });
  // remove cards moved away
  cards=cards.filter(function(c){
    var orig=getOrigWeekId(c);
    var assigned=cardWeekAssign[c.id];
    if(assigned&&assigned!==wid)return false;
    return true;
  });
  return cards;
}
function sortedCards(wid,cards){
  var so=sortOrders[wid];
  var ord=cardOrder[wid];
  if(ord&&ord.length){
    var byId={};cards.forEach(function(c){byId[c.id]=c;});
    var res=[];
    ord.forEach(function(id){if(byId[id])res.push(byId[id]);});
    cards.forEach(function(c){if(res.indexOf(c)<0)res.push(c);});
    return res;
  }
  if(so==='artist'){return cards.slice().sort(function(a,b){return a.artist.localeCompare(b.artist);});}
  if(so==='day'){return cards.slice().sort(function(a,b){return parseDate(a.day)-parseDate(b.day);});}
  return cards;
}
function tagLabel(t){
  if(t==='perf')return 'MV Release';
  if(t==='int')return 'Release';
  if(t==='shoot')return 'Upcoming';
  return t;
}
function parseDate(str){
  if(!str||str==='TBD')return Infinity;
  var months={Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  // "Mon Apr 7" or "Apr 7" or "Apr 7, 2025"
  var m=str.match(/([A-Z][a-z]{2})\s+(\d+)/);
  if(m){var yr=2026;var m2=str.match(/(\d{4})/);if(m2)yr=parseInt(m2[1]);return new Date(yr,months[m[1]]||0,parseInt(m[2])).getTime();}
  return Infinity;
}
function getCountdown(c){
  if(!c)return null;
  var day=dayOverrides[c.id]||c.day;
  if(!day||day==='TBD')return null;
  var ts=parseDate(day);
  if(ts===Infinity)return null;
  var now=new Date();now.setHours(0,0,0,0);
  var diff=Math.round((ts-now.getTime())/(1000*60*60*24));
  if(diff<0)return {text:(Math.abs(diff)===1?'1 day ago':Math.abs(diff)+' days ago'),cls:'cd-overdue'};
  if(diff===0)return {text:'Today!',cls:'cd-today'};
  if(diff===1)return {text:'Tomorrow',cls:'cd-soon'};
  if(diff<=7)return {text:'In '+diff+' days',cls:'cd-soon'};
  return {text:'In '+diff+' days',cls:'cd-ok'};
}
function getCardStatus(c){
  if(uploadedStatus[c.id])return 'done';
  var day=dayOverrides[c.id]||c.day;
  if(!day||day==='TBD')return 'ok';
  var ts=parseDate(day);
  if(ts===Infinity)return 'ok';
  var now=new Date();now.setHours(0,0,0,0);
  var diff=Math.round((ts-now.getTime())/(1000*60*60*24));
  if(diff<0)return 'overdue';
  if(diff<=7)return 'soon';
  return 'ok';
}

// ========================= AUTO-DATE SLOTS =========================
// Each scheduled week has upload slots: position in the column = upload date
// Hardcoded to match the exact intended schedule
var WEEK_SLOTS={
  'w1':['Tue Mar 25','Thu Mar 27'],
  'w2':['Tue Apr 1','Thu Apr 3'],
  'w3':['Tue Apr 8','Thu Apr 10']
};
function getWeekSlots(wid){return WEEK_SLOTS[wid]||null;}
// Assign dates from slots to cards based on their sorted position
function autoAssignDates(wid,sortedAllCards){
  var slots=getWeekSlots(wid);
  if(!slots)return;
  sortedAllCards.forEach(function(c,i){
    var newDay=i<slots.length?slots[i]:'TBD';
    dayOverrides[c.id]=newDay;
    c.day=newDay;
  });
}

// ========================= PERSISTENCE =========================
function persistState(){
  var stKey=currentSeason===1?LSK:LSK_S2;
  var delKey=currentSeason===1?LSDK:LSDK_S2;
  try{
    var sv={
      up:uploadedStatus,ed:editedStatus,dl:detailLabels,dy:dayOverrides,sh:shootOverrides,
      yl:youtubeLinks,cn:cardNotes,cw:cardWeekAssign,
      cwo:customWeeks,cc:customCards,so:sortOrders,al:activityLog,co:cardOrder
    };
    localStorage.setItem(stKey,JSON.stringify(sv));
    var dids=Object.keys(deletedCards).filter(function(k){return deletedCards[k];});
    localStorage.setItem(delKey,JSON.stringify(dids));
    showSave('saved');
  } catch(e){showSave('error');}
}
function showSave(st){
  var el=document.getElementById('save-indicator');
  var tx=document.getElementById('save-text');
  if(!el)return;
  el.className='visible '+st;
  tx.textContent=st==='saved'?'Saved':st==='saving'?'Saving\u2026':'Error saving';
  clearTimeout(saveTimer);
  saveTimer=setTimeout(function(){el.className='';},2000);
}
function initBoard(sv){
  if(!sv)return;
  if(sv.up)Object.assign(uploadedStatus,sv.up);
  if(sv.ed)Object.assign(editedStatus,sv.ed);
  if(sv.dl)Object.assign(detailLabels,sv.dl);
  if(sv.dy)Object.assign(dayOverrides,sv.dy);
  if(sv.sh)Object.assign(shootOverrides,sv.sh);
  if(sv.yl)Object.assign(youtubeLinks,sv.yl);
  if(sv.cn)Object.assign(cardNotes,sv.cn);
  if(sv.cw)Object.assign(cardWeekAssign,sv.cw);
  if(sv.cwo&&sv.cwo.length)customWeeks=sv.cwo;
  if(sv.cc&&sv.cc.length)customCards=sv.cc;
  if(sv.so)Object.assign(sortOrders,sv.so);
  if(sv.al&&sv.al.length)activityLog=sv.al;
  if(sv.co)Object.assign(cardOrder,sv.co);
  // apply overrides to card objects
  getAllCards().forEach(function(c){
    if(dayOverrides[c.id])c.day=dayOverrides[c.id];
    if(shootOverrides[c.id])c.shoot=shootOverrides[c.id];
  });
}

// ========================= SEASON SWITCH =========================
function updateSeasonUI(){
  var b1=document.getElementById('season-s1-btn');
  var b2=document.getElementById('season-s2-btn');
  if(b1)b1.classList.toggle('active',currentSeason===1);
  if(b2)b2.classList.toggle('active',currentSeason===2);
}
function switchSeason(n){
  if(n===currentSeason)return;
  persistState();
  currentSeason=n;
  uploadedStatus={};editedStatus={};detailLabels={};deletedCards={};dayOverrides={};shootOverrides={};
  youtubeLinks={};cardNotes={};cardWeekAssign={};
  customWeeks=[];customCards=[];sortOrders={};activityLog=[];cardOrder={};
  _milestoneShown={};
  activeFilter='all';searchQuery='';
  var si=document.getElementById('search-input');if(si)si.value='';
  document.querySelectorAll('.filter-btn').forEach(function(b){
    b.classList.toggle('active',b.dataset.filter==='all');
  });
  getActiveBaseWeeks().forEach(function(w){
    w.cards.forEach(function(c){detailLabels[c.id]=c.detail;});
  });
  if(n===1){
    ['u1','u2','u3','u4','u5','u6','d1','d2','d3'].forEach(function(id){
      uploadedStatus[id]=true;
    });
  }
  var stKey=n===1?LSK:LSK_S2;
  var delKey=n===1?LSDK:LSDK_S2;
  var saved=null;
  try{var raw=localStorage.getItem(stKey);if(raw)saved=JSON.parse(raw);}catch(e){}
  var dels=null;
  try{var rd=localStorage.getItem(delKey);if(rd)dels=JSON.parse(rd);}catch(e){}
  initBoard(saved);
  if(dels&&dels.length){dels.forEach(function(id){deletedCards[id]=true;});}
  _hist=[_snap()];_hi=0;_upUR();
  updateSeasonUI();
  renderBoard();
  updateStats();
}

// ========================= STATS =========================
function updateStats(){
  var all=getAllCards().filter(function(c){return !deletedCards[c.id];});
  var done=all.filter(function(c){return uploadedStatus[c.id];}).length;
  var total=all.length;
  var pct=total?Math.round(done/total*100):0;

  // overall
  setBar('bar-overall','pn-overall','pd-overall',done,total,pct);

  // backlog (w0 / s2_w0)
  var bwid=currentSeason===1?'w0':'s2_w0';
  var bCards=getCardsForWeek(bwid).filter(function(c){return !deletedCards[c.id];});
  var bDone=bCards.filter(function(c){return uploadedStatus[c.id];}).length;
  setBar('bar-backlog','pn-backlog','pd-backlog',bDone,bCards.length,bCards.length?Math.round(bDone/bCards.length*100):0);

  // pipeline
  var pipeWids=currentSeason===1?['w1','w2','w3']:['s2_w1'];
  var pCards=[];
  pipeWids.forEach(function(wid){
    getCardsForWeek(wid).forEach(function(c){if(!deletedCards[c.id])pCards.push(c);});
  });
  var pDone=pCards.filter(function(c){return uploadedStatus[c.id];}).length;
  setBar('bar-pipeline','pn-pipeline','pd-pipeline',pDone,pCards.length,pCards.length?Math.round(pDone/pCards.length*100):0);

  // scoreboard
  var sbt=document.getElementById('sb-total');
  var sbd=document.getElementById('sb-done');
  var sbq=document.getElementById('sb-queue');
  var sbtb=document.getElementById('sb-total-bar');
  var sdtb=document.getElementById('sb-done-bar');
  var sqtb=document.getElementById('sb-queue-bar');
  if(sbt)sbt.textContent=total;
  if(sbd)sbd.textContent=done;
  if(sbq)sbq.textContent=total-done;
  if(sdtb)sdtb.style.width=(total?Math.round(done/total*100):0)+'%';
  if(sqtb)sqtb.style.width=(total?Math.round((total-done)/total*100):0)+'%';

  checkMilestones(done,total);
}
function setBar(barId,numId,denId,done,total,pct){
  var b=document.getElementById(barId);
  var n=document.getElementById(numId);
  var d=document.getElementById(denId);
  if(b)b.style.width=pct+'%';
  if(n)n.textContent=done;
  if(d)d.textContent=total;
}

// ========================= MILESTONE / CONFETTI =========================
function triggerConfetti(){
  var colors=['#ff2d78','#3b82f6','#22c55e','#f59e0b','#ec4899','#8b5cf6','#ffffff'];
  for(var i=0;i<180;i++){
    (function(){
      var el=document.createElement('div');
      el.style.cssText='position:fixed;top:-10px;z-index:9999;pointer-events:none;border-radius:2px;';
      el.style.left=Math.random()*100+'vw';
      el.style.width=(6+Math.random()*8)+'px';
      el.style.height=(8+Math.random()*14)+'px';
      el.style.background=colors[Math.floor(Math.random()*colors.length)];
      el.style.opacity=0.9;
      document.body.appendChild(el);
      var dur=2200+Math.random()*2200;
      var xDrift=(Math.random()-0.5)*320;
      var start=null;
      function animate(ts){
        if(!start)start=ts;
        var p=(ts-start)/dur;
        if(p>=1){el.remove();return;}
        var y=p*110;
        var x=xDrift*p;
        var rot=p*720*(Math.random()>0.5?1:-1);
        el.style.transform='translate('+x+'vw,'+y+'vh) rotate('+rot+'deg)';
        el.style.opacity=p>0.8?(1-p)*5:0.9;
        requestAnimationFrame(animate);
      }
      requestAnimationFrame(animate);
    })();
  }
}
function checkMilestones(done,total){
  if(!total)return;
  var pct=done/total;
  [0.25,0.5,0.75,1.0].forEach(function(p){
    var key=currentSeason+'_'+p;
    if(pct>=p&&!_milestoneShown[key]){
      _milestoneShown[key]=true;
      triggerMilestone(Math.round(p*100),done,total);
    }
  });
}
function triggerMilestone(pct,done,total){
  for(var i=0;i<3;i++){
    (function(delay){setTimeout(triggerConfetti,delay);})(i*600);
  }
  var banner=document.getElementById('milestone-banner');
  var pctEl=document.getElementById('ms-pct-text');
  var lblEl=document.getElementById('ms-label-text');
  if(!banner)return;
  if(pctEl)pctEl.textContent=pct+'%';
  if(lblEl){
    if(pct===100)lblEl.textContent='All '+total+' videos uploaded! \ud83c\udf89';
    else lblEl.textContent=done+' of '+total+' uploaded';
  }
  banner.classList.add('show');
  setTimeout(function(){banner.classList.remove('show');},5000);
}

// ========================= RENDER BOARD =========================
function applyFilterSearch(cards){
  return cards.filter(function(c){
    if(deletedCards[c.id])return false;
    var et=uploadedStatus[c.id]?'done':editedStatus[c.id]?'edited':c.type;
    if(activeFilter!=='all'&&activeFilter!=='overdue'&&et!==activeFilter)return false;
    if(activeFilter==='overdue'){
      var st=getCardStatus(c);
      if(st!=='overdue')return false;
    }
    if(searchQuery){
      var q=searchQuery.toLowerCase();
      var artist=(c.artist||'').toLowerCase();
      var det=(detailLabels[c.id]||c.detail||'').toLowerCase();
      if(artist.indexOf(q)<0&&det.indexOf(q)<0)return false;
    }
    return true;
  });
}
function renderBoard(){
  if(currentView!=='board')return;
  var board=document.getElementById('board');
  if(!board)return;
  board.innerHTML='';
  var weeks=getAllWeeks();
  weeks.forEach(function(wk){
    var allCards=getCardsForWeek(wk.id).filter(function(c){return !deletedCards[c.id];});
    var sorted=sortedCards(wk.id,allCards);
    // Auto-assign dates from week slots (position = priority = date)
    autoAssignDates(wk.id,sorted);
    var visible=applyFilterSearch(sorted);
    var col=document.createElement('div');
    col.className='column';

    var hdr=document.createElement('div');
    hdr.className='col-header';
    var so=sortOrders[wk.id]||'default';
    hdr.innerHTML='<div class="col-title-wrap"><div class="col-title">'+wk.label+'</div>'+(wk.date?'<div class="col-date">'+wk.date+'</div>':'')+'</div>'+
      '<div class="col-right">'+
      '<div class="col-count">'+visible.length+'</div>'+
      '<button class="sort-btn" data-week="'+wk.id+'" data-sort="add" title="Add card">\uFF0B</button>'+
      '</div>';
    col.appendChild(hdr);

    var cardsEl=document.createElement('div');
    cardsEl.className='col-cards';
    cardsEl.dataset.week=wk.id;
    setupDropZone(cardsEl);

    visible.forEach(function(c){
      var cardEl=buildCardEl(c,wk.id);
      cardsEl.appendChild(cardEl);
    });
    col.appendChild(cardsEl);

    // add card button at bottom
    var addBtn=document.createElement('button');
    addBtn.className='add-card-btn';
    addBtn.dataset.week=wk.id;
    addBtn.textContent='+ Add card';
    addBtn.addEventListener('click',function(){openAddCard(wk.id);});
    col.appendChild(addBtn);

    board.appendChild(col);
  });

  // Add column button
  var addColBtn=document.createElement('div');
  addColBtn.className='add-col-btn';
  addColBtn.innerHTML='<button class="header-btn" id="add-col-trigger">\uFF0B Column</button>';
  addColBtn.querySelector('button').addEventListener('click',function(){
    document.getElementById('add-col-overlay').classList.add('open');
  });
  board.appendChild(addColBtn);

  updateStats();
}

function buildCardEl(c,wid){
  var up=uploadedStatus[c.id];
  var et=up?'done':c.type;
  var st=getCardStatus(c);
  var cd=getCountdown(c);

  var ed=editedStatus[c.id];
  var card=document.createElement('div');
  card.className='card '+(up?'done':ed?'edited':c.type);
  card.dataset.id=c.id;
  card.draggable=true;

  var badge='';
  if(up)badge='<div class="done-badge">\u2713 Uploaded</div>';
  else if(ed)badge='<div class="edited-badge">\u2713 Done Editing</div>';
  else if(st==='overdue')badge='<div class="overdue-badge">\u26a0 Overdue</div>';
  else if(st==='soon')badge='<div class="soon-badge">\u23f0 This week</div>';

  var dayTxt=dayOverrides[c.id]||c.day||'TBD';
  var shootTxt=shootOverrides[c.id]||c.shoot||'TBD';
  var dayClass='card-day'+(st==='overdue'&&!up?' overdue':'');
  var notesEl=cardNotes[c.id]?'<div class="card-note">\u{1F4AC} '+escHtml(cardNotes[c.id].substring(0,60))+'</div>':'';
  var ytEl=youtubeLinks[c.id]?'<div class="card-yt">\u25B6 <a href="'+escHtml(youtubeLinks[c.id])+'" target="_blank" onclick="event.stopPropagation();">Watch</a></div>':'';
  var cdEl=cd?'<div class="countdown '+cd.cls+'">'+cd.text+'</div>':'';

  card.innerHTML=badge+
    '<div class="card-top">'+
    '<div class="card-artist">'+escHtml(c.artist)+'</div>'+
    (et==='done'||ed?'':'<div class="card-tag '+et+'">'+tagLabel(et)+'</div>')+
    '</div>'+
    '<div class="card-detail-wrap"><span class="card-detail">'+escHtml(detailLabels[c.id]||c.detail)+'</span></div>'+
    '<div class="card-meta">'+
    '<div class="'+dayClass+'">\ud83d\udcc5 '+escHtml(dayTxt)+'</div>'+
    '</div>'+
    notesEl+ytEl+cdEl;

  card.addEventListener('click',function(){openCard(c.id);});
  card.addEventListener('dragstart',function(e){
    dragSrcId=c.id;
    e.dataTransfer.setData('text/plain',c.id);
    e.dataTransfer.effectAllowed='move';
    setTimeout(function(){card.classList.add('dragging');},0);
  });
  card.addEventListener('dragend',function(){
    card.classList.remove('dragging');
    document.querySelectorAll('.drop-placeholder').forEach(function(p){p.remove();});
  });
  return card;
}

function escHtml(s){
  if(!s)return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function setupDropZone(cardsEl){
  cardsEl.addEventListener('dragover',function(e){
    e.preventDefault();
    e.dataTransfer.dropEffect='move';
    cardsEl.classList.add('drag-over');
    // Remove existing placeholders
    document.querySelectorAll('.drop-placeholder').forEach(function(p){p.remove();});
    // Find insertion point
    var ph=document.createElement('div');
    ph.className='drop-placeholder';
    var cardEls=cardsEl.querySelectorAll('.card:not(.dragging)');
    var inserted=false;
    for(var i=0;i<cardEls.length;i++){
      var rect=cardEls[i].getBoundingClientRect();
      if(e.clientY<rect.top+rect.height/2){
        cardsEl.insertBefore(ph,cardEls[i]);
        inserted=true;break;
      }
    }
    if(!inserted)cardsEl.appendChild(ph);
  });
  cardsEl.addEventListener('dragleave',function(e){
    if(!cardsEl.contains(e.relatedTarget)){
      cardsEl.classList.remove('drag-over');
      document.querySelectorAll('.drop-placeholder').forEach(function(p){p.remove();});
    }
  });
  cardsEl.addEventListener('drop',function(e){
    e.preventDefault();
    cardsEl.classList.remove('drag-over');
    document.querySelectorAll('.drop-placeholder').forEach(function(p){p.remove();});
    var did=e.dataTransfer.getData('text/plain');
    if(!did)return;
    var twid=cardsEl.dataset.week;
    var srcWid=cardWeekAssign[did]||getOrigWeekId(findCard(did));
    // Find drop target card
    var dropTarget=null;
    var cardEls=cardsEl.querySelectorAll('.card:not(.dragging)');
    for(var ci=0;ci<cardEls.length;ci++){
      var rect=cardEls[ci].getBoundingClientRect();
      if(e.clientY<rect.top+rect.height/2){dropTarget=cardEls[ci].dataset.id;break;}
    }
    if(srcWid!==twid){
      cardWeekAssign[did]=twid;
      var fc=findCard(did);
      var wk=getAllWeeks().filter(function(w){return w.id===twid;})[0];
      // Date auto-assigns from slot position via renderBoard → autoAssignDates
      logActivity('\u21c6 '+(fc?fc.artist:did)+' moved to '+(wk?wk.label:twid));
    }
    var curCards=getCardsForWeek(twid).filter(function(c){return !deletedCards[c.id];});
    var ordered=sortedCards(twid,curCards).map(function(c){return c.id;});
    ordered=ordered.filter(function(id){return id!==did;});
    if(dropTarget){
      var idx=ordered.indexOf(dropTarget);
      if(idx>=0)ordered.splice(idx,0,did);
      else ordered.push(did);
    } else {
      ordered.push(did);
    }
    cardOrder[twid]=ordered;
    pushHistory();renderBoard();persistState();
  });
}

