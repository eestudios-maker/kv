// ========================= TIMELINE VIEW =========================
function getTimelineDates(){
  var dates=[];
  var seen={};
  getAllCards().filter(function(c){return !deletedCards[c.id];}).forEach(function(c){
    var d=dayOverrides[c.id]||c.day;
    if(!d||d==='TBD')return;
    var ts=parseDate(d);
    if(ts===Infinity)return;
    var key=new Date(ts).toISOString().split('T')[0];
    if(!seen[key]){seen[key]=true;dates.push({key:key,ts:ts,label:d.replace(/^[A-Z][a-z]{2} /,'')});}
  });
  dates.sort(function(a,b){return a.ts-b.ts;});
  return dates;
}
function renderTimeline(){
  var view=document.getElementById('timeline-view');
  if(!view)return;
  view.innerHTML='';
  var dates=getTimelineDates();
  if(!dates.length){
    view.innerHTML='<div style="padding:40px 32px;color:var(--muted);text-align:center;">No upload dates set yet.</div>';
    return;
  }
  // Group cards by artist
  var all=getAllCards().filter(function(c){return !deletedCards[c.id];});
  var artists=[];
  var artistSeen={};
  all.forEach(function(c){if(!artistSeen[c.artist]){artistSeen[c.artist]=true;artists.push(c.artist);}});
