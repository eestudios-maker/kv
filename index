        chip.addEventListener('click',function(){openCard(c.id);});
        td.appendChild(chip);
      });
      tr.appendChild(td);
    });
    tbody.appendChild(tr);
  });
  table.appendChild(tbody);
  wrap.appendChild(table);
  view.appendChild(wrap);
}

// ========================= CALENDAR VIEW =========================
function renderCalendar(){
  var grid=document.getElementById('cal-grid');
  var lbl=document.getElementById('cal-month-label');
  if(!grid)return;
  var months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  if(lbl)lbl.textContent=months[calMonth]+' '+calYear;
  grid.innerHTML='';
  // DOW headers
  ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(d){
    var hd=document.createElement('div');
    hd.className='cal-dow';hd.textContent=d;grid.appendChild(hd);
  });
  var firstDay=new Date(calYear,calMonth,1).getDay();
  var daysInMonth=new Date(calYear,calMonth+1,0).getDate();
  // Build card map by date string
  var cardMap={};
  getAllCards().filter(function(c){return !deletedCards[c.id];}).forEach(function(c){
    var d=dayOverrides[c.id]||c.day;
    if(!d||d==='TBD')return;
    var ts=parseDate(d);
    if(ts===Infinity)return;
    var dt=new Date(ts);
    if(dt.getFullYear()===calYear&&dt.getMonth()===calMonth){
      var key=dt.getDate();
      if(!cardMap[key])cardMap[key]=[];
      cardMap[key].push(c);
    }
  });
  for(var i=0;i<firstDay;i++){
    var emp=document.createElement('div');emp.className='cal-cell empty';grid.appendChild(emp);
  }
  var today=new Date();
  for(var d=1;d<=daysInMonth;d++){
    var cell=document.createElement('div');
    cell.className='cal-cell';
    var isToday=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
    if(isToday)cell.classList.add('today');
    var dnum=document.createElement('div');
    dnum.className='cal-day-num'+(isToday?' today':'');
    dnum.textContent=d;cell.appendChild(dnum);
    if(cardMap[d]){
      cardMap[d].forEach(function(c){
        var chip=document.createElement('div');
        var up=uploadedStatus[c.id];
        var cls='cal-chip '+(up?'done':c.type);
        chip.className=cls;
        chip.textContent=(up?'\u2713 ':'')+escHtml(c.artist);
        chip.title=(detailLabels[c.id]||c.detail);
        chip.addEventListener('click',function(e){e.stopPropagation();openCard(c.id);});
        cell.appendChild(chip);
      });
    }
    grid.appendChild(cell);
  }
}

